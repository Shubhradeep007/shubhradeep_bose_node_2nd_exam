<%- include('../partials/header') %>

<div class="flex bg-white/5 backdrop-blur-2xl rounded-3xl shadow-2xl border border-white/10 min-h-[70vh] mb-12 mt-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent pointer-events-none"></div>

  <%- include('../partials/admin-sidebar') %>
  
  <div class="flex-grow p-8 bg-black/10 rounded-r-3xl relative z-10 overflow-y-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-white tracking-tight">Admin Dashboard</h1>
      <p class="text-slate-400 mt-2">Welcome back to the store management panel.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white/5 backdrop-blur-md rounded-2xl shadow-xl border border-white/10 p-6 flex items-center gap-6 overflow-hidden relative group">
        <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-indigo-500/10 rounded-full group-hover:scale-110 transition-transform duration-500"></div>
        <div class="bg-indigo-500/20 border border-indigo-500/30 p-4 rounded-xl text-indigo-300 shadow-lg z-10 backdrop-blur-sm">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
        </div>
        <div class="z-10 py-2 px-1 rounded">
          <p class="text-sm font-medium text-slate-400 uppercase tracking-widest">Total Products</p>
          <h2 class="text-4xl font-bold text-white mt-1 drop-shadow-md"><%= totalProducts %></h2>
        </div>
      </div>

      <div class="bg-white/5 backdrop-blur-md rounded-2xl shadow-xl border border-white/10 p-6 flex items-center gap-6 overflow-hidden relative group">
        <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-indigo-500/10 rounded-full group-hover:scale-110 transition-transform duration-500"></div>
        <div class="bg-indigo-500/20 border border-indigo-500/30 p-4 rounded-xl text-indigo-300 shadow-lg z-10 backdrop-blur-sm">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        </div>
        <div class="z-10 py-2 px-1 rounded">
          <p class="text-sm font-medium text-slate-400 uppercase tracking-widest">Total Categories</p>
          <h2 class="text-4xl font-bold text-white mt-1 drop-shadow-md"><%= totalCategories %></h2>
        </div>
      </div>
    </div>

    <div class="bg-white/5 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/10 p-6 relative">
      <h3 class="text-lg font-bold text-white mb-6 border-b border-white/10 pb-4">Quick Actions</h3>
      <div class="flex gap-4">
        <a href="/admin/products/add" class="flex items-center gap-2 bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-200 px-5 py-3 rounded-xl border border-indigo-500/30 shadow-lg transition-all font-medium backdrop-blur-sm">
          <svg class="w-5 h-5 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Add New Product
        </a>
        <a href="/admin/categories/add" class="flex items-center gap-2 bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-200 px-5 py-3 rounded-xl border border-indigo-500/30 shadow-lg transition-all font-medium backdrop-blur-sm">
          <svg class="w-5 h-5 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Add New Category
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
