<%- include('../../partials/header') %>

<div class="flex bg-white/5 backdrop-blur-2xl rounded-3xl shadow-2xl border border-white/10 min-h-[70vh] mb-12 mt-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent pointer-events-none"></div>

  <%- include('../../partials/admin-sidebar') %>
  
  <div class="flex-grow p-8 bg-black/10 rounded-r-3xl relative z-10 overflow-y-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-extrabold text-white tracking-tight">Manage Products</h1>
      <a href="/admin/products/add" class="bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-100 border border-indigo-500/30 font-medium py-2.5 px-5 rounded-xl shadow-lg transition-all flex items-center gap-2 backdrop-blur-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Add Product
      </a>
    </div>

    <div class="bg-white/5 backdrop-blur-xl rounded-2xl shadow-xl border border-white/10 overflow-hidden relative">
      <% if (products && products.length > 0) { %>
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black/20 text-slate-300 text-sm uppercase tracking-wider border-b border-white/10">
              <th class="px-6 py-5 font-bold w-20 text-center">Image</th>
              <th class="px-6 py-5 font-bold">Name</th>
              <th class="px-6 py-5 font-bold">Category</th>
              <th class="px-6 py-5 font-bold text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% products.forEach(product => { %>
              <tr class="hover:bg-white/5 transition-colors group align-middle">
                <td class="px-6 py-4">
                  <% if (product.image) { %>
                    <div class="relative w-14 h-14 rounded-xl overflow-hidden shadow-md border border-white/10">
                      <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    </div>
                  <% } else { %>
                    <div class="w-14 h-14 bg-black/30 rounded-xl flex items-center justify-center border border-white/5 text-slate-500 shadow-inner">
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                  <% } %>
                </td>
                <td class="px-6 py-4 font-bold text-white text-lg"><%= product.name %></td>
                <td class="px-6 py-4 text-slate-400">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-indigo-500/20 text-indigo-300 border border-indigo-500/20">
                    <%= product.category ? product.category.name : 'Unknown' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-right space-x-2">
                  <a href="/admin/products/edit/<%= product._id %>" class="inline-flex items-center text-indigo-300 hover:text-white bg-indigo-500/10 border border-indigo-500/20 hover:bg-indigo-500/30 p-2.5 rounded-xl transition-all shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  </a>
                  <form action="/admin/products/delete/<%= product._id %>?_method=DELETE" method="POST" class="inline-block" onsubmit="return confirm('Are you sure you want to delete this product?');">
                    <button type="submit" class="inline-flex items-center text-rose-300 hover:text-white bg-rose-500/10 border border-rose-500/20 hover:bg-rose-500/30 p-2.5 rounded-xl transition-all shadow-sm">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="py-16 flex flex-col items-center justify-center text-slate-400">
          <svg class="w-20 h-20 text-white/10 mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
          <p class="text-xl font-medium text-white mb-2">No products found</p>
          <p class="text-slate-500 text-sm mb-6">You haven't added any products yet.</p>
          <a href="/admin/products/add" class="bg-indigo-500/20 border border-indigo-500/30 text-indigo-200 hover:bg-indigo-500/30 px-6 py-2.5 rounded-xl font-medium transition-all shadow-lg text-sm">Create your first product</a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
