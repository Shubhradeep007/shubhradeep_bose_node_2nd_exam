<%- include('./partials/header') %>

<div class="flex-grow flex items-center justify-center -mt-10">
  <div class="bg-white/5 backdrop-blur-2xl rounded-3xl shadow-2xl border border-white/10 p-12 max-w-lg w-full text-center relative overflow-hidden group">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-transparent pointer-events-none group-hover:from-indigo-500/20 transition-all duration-700"></div>
    
    <div class="relative z-10 flex flex-col items-center">
      <div class="w-24 h-24 bg-rose-500/10 border border-rose-500/20 rounded-full flex items-center justify-center mb-6 shadow-[0_0_40px_rgba(244,63,94,0.15)] group-hover:scale-110 transition-transform duration-500">
        <svg class="w-12 h-12 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
      </div>
      
      <h1 class="text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 to-indigo-100 mb-2 tracking-tighter drop-shadow-lg">
        404
      </h1>
      
      <h2 class="text-2xl font-bold text-white mb-4">Page Not Found</h2>
      
      <p class="text-slate-400 mb-8 max-w-sm mx-auto leading-relaxed">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>
      
      <div class="flex gap-4">
        <button onclick="window.history.back()" class="bg-slate-800/50 hover:bg-slate-800/80 border border-slate-700 text-slate-300 font-medium py-3 px-6 rounded-xl shadow-lg transition-all backdrop-blur-sm">
          Go Back
        </button>
        <a href="/" class="bg-indigo-500/20 hover:bg-indigo-500/30 border border-indigo-500/30 text-indigo-100 font-bold py-3 px-6 rounded-xl shadow-lg hover:shadow-indigo-500/20 transition-all backdrop-blur-sm flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Return Home
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
