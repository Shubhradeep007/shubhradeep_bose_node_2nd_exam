<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Product Management System' %></title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-black text-slate-200 font-sans min-h-screen flex flex-col relative">

  <!-- Full Black Mesh Background -->
  <div class="fixed inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.15),rgba(0,0,0,0))] pointer-events-none z-0"></div>

  <!-- Navbar -->
  <header class="sticky top-0 z-50 backdrop-blur-xl bg-black/60 border-b border-white/10 shadow-2xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <!-- <a href="/" class="text-xl font-bold flex items-center gap-2 text-white hover:text-indigo-400 transition-colors">
        <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
        Shopify
      </a> -->
      <nav class="flex gap-4 items-center w-full justify-end">
        <a href="/" class="text-sm font-medium text-slate-300 hover:text-white transition-colors border border-transparent hover:border-white/10 px-3 py-1.5 rounded-lg">Home</a>
        <% if (typeof user !== 'undefined' && user) { %>
          <div class="flex items-center gap-3 pl-4 border-l border-white/10">
            <span class="text-sm font-medium text-indigo-300"><%= user.name %></span>
            <% if (user.role === 'admin') { %>
              <a href="/admin" class="text-xs font-bold text-indigo-400 hover:text-white transition-colors bg-white/5 px-3 py-1.5 rounded-lg border border-white/10 shadow-sm shadow-black shrink-0">Admin Panel</a>
            <% } %>
            <a href="/auth/logout" class="bg-rose-500/10 hover:bg-rose-500/20 text-rose-300 border border-rose-500/20 text-xs px-4 py-1.5 rounded-full backdrop-blur-sm transition-all shadow-lg font-bold">Sign Out</a>
          </div>
        <% } else { %>
          <div class="flex items-center gap-3 pl-4 border-l border-white/10">
            <a href="/auth/login" class="text-sm font-medium text-slate-300 hover:text-white transition-colors border border-transparent hover:border-white/10 px-3 py-1.5 rounded-lg">Sign In</a>
            <a href="/auth/register" class="bg-indigo-500/20 hover:bg-indigo-500/30 border border-indigo-500/30 text-indigo-100 text-xs px-4 py-1.5 rounded-full font-bold shadow-lg backdrop-blur-sm transition-all hover:shadow-indigo-500/20 relative">Register</a>
          </div>
        <% } %>
      </nav>
    </div>
  </header>

  <!-- Flash Messages -->
  <div class="max-w-4xl mx-auto px-4 w-full mt-6 relative z-10">
    <% if (typeof success !== 'undefined' && success) { %>
      <% const succArray = Array.isArray(success) ? success : [success]; %>
      <% if (succArray.length > 0) { %>
        <% succArray.forEach(msg => { %>
          <div class="mb-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 backdrop-blur-xl px-5 py-3 rounded-xl shadow-2xl relative flex items-center gap-3" role="alert">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span class="block sm:inline font-medium"><%= msg %></span>
          </div>
        <% }) %>
      <% } %>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <% const errArray = Array.isArray(error) ? error : [error]; %>
      <% if (errArray.length > 0) { %>
        <% errArray.forEach(msg => { %>
          <div class="mb-4 bg-rose-500/10 border border-rose-500/20 text-rose-400 backdrop-blur-xl px-5 py-3 rounded-xl shadow-2xl relative flex items-center gap-3" role="alert">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span class="block sm:inline font-medium"><%= msg %></span>
          </div>
        <% }) %>
      <% } %>
    <% } %>
  </div>
  
  <main class="flex-grow max-w-7xl mx-auto px-4 w-full py-6 relative z-10">
