<%- include('../partials/header') %>

<div class="max-w-md mx-auto bg-white/5 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/10 overflow-hidden transform transition-all mt-10">
  <div class="px-8 py-6">
    <h2 class="text-2xl font-bold text-center text-white mb-8">Customer Login</h2>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="mb-6 bg-red-50 border-l-4 border-red-500 text-red-700 p-4" role="alert">
        <div class="flex flex-col gap-1">
          <% errors.forEach(err => { %>
            <span><%= err %></span>
          <% }) %>
        </div>
      </div>
    <% } %>

    <form action="/auth/login" method="POST" class="space-y-5">
      <div>
        <label for="email" class="block text-sm font-medium text-slate-300 mb-1">Email Address</label>
        <input type="email" id="email" name="email" value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>" required class="w-full px-4 py-2 bg-black/20 border border-white/10 rounded-lg focus:ring-1 focus:ring-indigo-400/50 focus:border-indigo-400/50 text-slate-200 outline-none transition-all placeholder-slate-500" placeholder="you@example.com">
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-slate-300 mb-1">Password</label>
        <input type="password" id="password" name="password" required class="w-full px-4 py-2 bg-black/20 border border-white/10 rounded-lg focus:ring-1 focus:ring-indigo-400/50 focus:border-indigo-400/50 text-slate-200 outline-none transition-all placeholder-slate-500" placeholder="••••••••">
      </div>

      <button type="submit" class="w-full bg-indigo-500/20 hover:bg-indigo-500/30 border border-indigo-500/30 text-indigo-100 font-semibold py-2.5 px-4 rounded-xl backdrop-blur-sm shadow-lg hover:shadow-indigo-500/20 transition-all">
        Sign In
      </button>
    </form>

    <div class="mt-6 text-center text-sm text-slate-400">
      Don't have an account? <a href="/auth/register" class="text-indigo-400 hover:text-indigo-300 font-medium">Register here</a>
    </div>

    <div class="mt-4 pt-4 border-t border-white/10 flex flex-col items-center justify-center text-sm text-slate-400">
      <a href="/auth/admin/login" class="text-indigo-400 hover:text-indigo-300 font-medium flex items-center gap-1 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4h.002M8 4a8 8 0 0116 0z"></path></svg>
        Admin Portal
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
