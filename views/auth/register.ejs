<%- include('../partials/header') %>

<div class="max-w-md mx-auto bg-white/5 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/10 overflow-hidden transform transition-all mt-10">
  <div class="px-8 py-6">
    <h2 class="text-2xl font-bold text-center text-white mb-8">Create an Account</h2>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="mb-6 bg-red-50 border-l-4 border-red-500 text-red-700 p-4" role="alert">
        <div class="flex flex-col gap-1">
          <% errors.forEach(err => { %>
            <span><%= err %></span>
          <% }) %>
        </div>
      </div>
    <% } %>

    <form action="/auth/register" method="POST" class="space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium text-slate-300 mb-1">Full Name</label>
        <input type="text" id="name" name="name" value="<%= typeof oldInput !== 'undefined' && oldInput.name ? oldInput.name : '' %>" required class="w-full px-4 py-2 bg-black/20 border border-white/10 rounded-lg focus:ring-1 focus:ring-indigo-400/50 focus:border-indigo-400/50 text-slate-200 outline-none transition-all placeholder-slate-500" placeholder="John Doe">
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-300 mb-1">Email Address</label>
        <input type="email" id="email" name="email" value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>" required class="w-full px-4 py-2 bg-black/20 border border-white/10 rounded-lg focus:ring-1 focus:ring-indigo-400/50 focus:border-indigo-400/50 text-slate-200 outline-none transition-all placeholder-slate-500" placeholder="you@example.com">
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-slate-300 mb-1">Password</label>
        <input type="password" id="password" name="password" required class="w-full px-4 py-2 bg-black/20 border border-white/10 rounded-lg focus:ring-1 focus:ring-indigo-400/50 focus:border-indigo-400/50 text-slate-200 outline-none transition-all placeholder-slate-500" placeholder="••••••••">
      </div>
      
      <div>
        <label for="confirmPassword" class="block text-sm font-medium text-slate-300 mb-1">Confirm Password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" required class="w-full px-4 py-2 bg-black/20 border border-white/10 rounded-lg focus:ring-1 focus:ring-indigo-400/50 focus:border-indigo-400/50 text-slate-200 outline-none transition-all placeholder-slate-500" placeholder="••••••••">
      </div>

      <button type="submit" class="w-full mt-2 bg-indigo-500/20 hover:bg-indigo-500/30 border border-indigo-500/30 text-indigo-100 font-semibold py-2.5 px-4 rounded-xl backdrop-blur-sm shadow-lg hover:shadow-indigo-500/20 transition-all">
        Sign Up
      </button>
    </form>

    <div class="mt-6 text-center text-sm text-slate-400">
      Already have an account? <a href="/auth/login" class="text-indigo-400 hover:text-indigo-300 font-medium">Log in here</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
